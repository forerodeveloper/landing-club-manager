---
const stats = [
  { v: "98%", l: "De padres pagan a tiempo", d: "Tasa de efectividad en el cobro de mensualidades" },
  { v: "+20h", l: "Horas ahorradas por semana", d: "Elimina planillas manuales y automatiza tareas repetitivas" },
  { v: "320+", l: "Clubes usan Club Manager", d: "En toda Latinoamérica y España" },
  { v: "$0", l: "Costo de implementación", d: "Te ayudamos a migrar tus datos sin costo" },
];
---

<section id="stats" class="border-y border-border bg-card">
  <div class="mx-auto grid max-w-7xl gap-8 px-4 py-16 sm:px-6 sm:grid-cols-2 lg:grid-cols-4">
    {stats.map((s) => (
      <div class="text-center">
        <p class="text-4xl font-bold tracking-tight text-gradient">{s.v}</p>
        <p class="mt-2 text-sm font-semibold">{s.l}</p>
        <p class="mt-1 text-sm text-muted-foreground leading-snug">{s.d}</p>
      </div>
    ))}
  </div>
</section>
