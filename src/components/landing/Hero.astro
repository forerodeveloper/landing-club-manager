  <script define:vars={{ sports: ['fútbol', 'básquetbol', 'vóley', 'natación', 'tenis', 'atletismo'] }}>
    const sportText = document.getElementById('sport-text');
    let currentIndex = 0;

    setInterval(() => {
      // Fade out
      sportText.style.transition = 'opacity 0.3s ease-in-out';
      sportText.style.opacity = '0';

      setTimeout(() => {
        // Change text
        currentIndex = (currentIndex + 1) % sports.length;
        sportText.textContent = sports[currentIndex];

        // Fade in
        sportText.style.opacity = '1';
      }, 300);
    }, 2500);
