---
const features = [
  {
    icon: "wallet",
    title: "Recaudo automático de padres",
    desc: "Mensualidades, matrículas, uniformes y torneos. Los padres descargan la app, reciben notificaciones de pago y gestionan todo desde su celular. También puedes enviar recordatorios por WhatsApp con un mensaje predefinido.",
    tag: "Top",
  },
  {
    icon: "calculator",
    title: "Contabilidad clara",
    desc: "Ingresos, gastos, conciliación y reportes listos para tu contador. Exporta a Excel o PDF en un clic.",
    tag: "Top",
  },
  {
    icon: "clock",
    title: "Horas y nómina de entrenadores",
    desc: "Registra asistencia, horas trabajadas y calcula salarios o bonificaciones por entrenador o asistente.",
    tag: "Top",
  },
  {
    icon: "message-circle",
    title: "WhatsApp integrado",
    desc: "Convocatorias, avisos y recordatorios de pago directos al chat de cada padre.",
  },
  {
    icon: "users",
    title: "Gestión de jugadores",
    desc: "Categorías sub-8 a senior, documentos médicos, estado activo/pausado y vista rápida.",
  },
  {
    icon: "calendar-check",
    title: "Asistencia en segundos",
    desc: "Check-in por sesión (mañana/tarde/noche). Reportes de asistencia y puntualidad.",
  },
  {
    icon: "bar-chart",
    title: "Dashboard en tiempo real",
    desc: "KPIs financieros, asistencia, jugadores activos y morosidad. Decisiones con datos.",
  },
  {
    icon: "smartphone",
    title: "App móvil para padres",
    desc: "Push notifications de pagos pendientes, convocatorias, inasistencias y más. Todo al alcance de un toque en su celular.",
    tag: "Top",
  },
];

const getIcon = (name: string) => {
  const icons = {
    "wallet": `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12V7H5a2 2 0 0 1 0-4h14v4"/><path d="M3 5v14a2 2 0 0 0 2 2h16v-5"/><path d="M18 12a2 2 0 0 0 0 4h4v-4Z"/></svg>`,
    "calculator": `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="16" height="20" x="4" y="2" rx="2"/><line x1="8" x2="16" y1="6" y2="6"/><line x1="16" x2="16" y1="14" y2="18"/><path d="M16 10h.01"/><path d="M12 10h.01"/><path d="M8 10h.01"/><path d="M12 14h.01"/><path d="M8 14h.01"/><path d="M12 18h.01"/><path d="M8 18h.01"/></svg>`,
    "clock": `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    "message-circle": `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>`,
    "users": `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    "calendar-check": `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/><path d="m9 16 2 2 4-4"/></svg>`,
    "bar-chart": `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" x2="12" y1="20" y2="10"/><line x1="18" x2="18" y1="20" y2="4"/><line x1="6" x2="6" y1="20" y2="16"/></svg>`,
    "smartphone": `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/></svg>`,
  };
  return icons[name] || icons["smartphone"];
};
---

<section id="features" class="mx-auto max-w-7xl px-4 py-24 sm:px-6">
  <div class="mx-auto max-w-2xl text-center">
    <p class="text-[11px] font-bold uppercase tracking-wider text-primary">Todo en una plataforma</p>
    <h2 class="mt-3 text-3xl font-bold tracking-tight sm:text-4xl">
      Lo que tu club necesita para crecer sin caos
    </h2>
    <p class="mt-4 text-muted-foreground">
      Reemplaza Excel, grupos de WhatsApp y cobros manuales por un sistema que trabaja por ti.
    </p>
  </div>

  <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
    {features.map((f) => (
      <div class="group relative rounded-2xl border border-border bg-card p-6 shadow-soft transition-all hover:-translate-y-1 hover:border-primary/40 hover:shadow-card">
        {f.tag && (
          <span class="absolute right-4 top-4 rounded-full bg-primary/10 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider text-primary">
            {f.tag}
          </span>
        )}
        <div class="grid h-11 w-11 place-items-center rounded-xl bg-gradient-hero text-primary-foreground shadow-glow" set:html={getIcon(f.icon)} />
        <h3 class="mt-4 text-lg font-semibold">{f.title}</h3>
        <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{f.desc}</p>
      </div>
    ))}
  </div>
</section>
