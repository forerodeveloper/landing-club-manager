---
---

<section id="descargar" class="relative overflow-hidden py-24 bg-slate-950">
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute top-1/2 left-1/2 h-[500px] w-[800px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-primary/10 blur-[120px]" />
  </div>

  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-4xl text-center">
      <h2 class="text-base font-bold uppercase tracking-[0.2em] text-primary mb-4">La Experiencia Completa</h2>
      <p class="text-4xl font-black tracking-tight text-white sm:text-6xl mb-8">
        Lleva tu club en el bolsillo con nuestra <span class="text-gradient">App Móvil</span>
      </p>
      <p class="text-lg leading-8 text-slate-400 mb-12 max-w-2xl mx-auto">
        Recibe notificaciones en tiempo real, confirma asistencia a convocatorias, gestiona pagos y mantén comunicación directa con tu equipo desde cualquier lugar.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
        <a href="https://apps.apple.com/co/app/clubsport-manager/id6768074360" target="_blank" rel="noopener noreferrer" class="bg-white/5 hover:bg-white/10 border border-white/10 p-4 rounded-xl flex items-center justify-center transition-all">
          <img src="https://upload.wikimedia.org/wikipedia/commons/3/3c/Download_on_the_App_Store_Badge.svg" alt="App Store" class="h-10" />
        </a>

        <a href="https://play.google.com/store/apps/details?id=com.fordev.clubsportmanager" target="_blank" rel="noopener noreferrer" class="bg-white/5 hover:bg-white/10 border border-white/10 p-4 rounded-xl flex items-center justify-center transition-all">
          <img src="https://upload.wikimedia.org/wikipedia/commons/7/78/Google_Play_Store_badge_EN.svg" alt="Play Store" class="h-10" />
        </a>
      </div>
    </div>

    
  </div>
</section>

<style>
  .text-gradient {
    background: linear-gradient(135deg, #10b981 0%, #3b82f6 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
</style>
