---
---

<section id="descargar" class="relative overflow-hidden py-24 bg-slate-950">
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute top-1/2 left-1/2 h-[500px] w-[800px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-primary/10 blur-[120px]" />
  </div>

  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-4xl text-center">
      <h2 class="text-base font-bold uppercase tracking-[0.2em] text-primary mb-4">La Experiencia Completa</h2>
      <p class="text-4xl font-black tracking-tight text-white sm:text-6xl mb-8">
        Lleva tu club en el bolsillo con nuestra <span class="text-gradient">App Móvil</span>
      </p>
      <p class="text-lg leading-8 text-slate-400 mb-12 max-w-2xl mx-auto">
        Recibe notificaciones en tiempo real, confirma asistencia a convocatorias, gestiona pagos y mantén comunicación directa con tu equipo desde cualquier lugar.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
        <a href="#" class="group relative flex items-center gap-4 bg-white/5 hover:bg-white/10 border border-white/10 p-6 rounded-2xl transition-all hover:scale-105 hover:border-primary/50">
          <div class="h-10 w-10 flex items-center justify-center">
            <svg viewBox="0 0 24 24" fill="white" class="h-8 w-8"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91 1.34.05 2.37.54 2.91 1.32-1.28.77-2.14 2.1-2.14 3.65 0 1.91 1.1 3.29 2.65 3.89-.21.51-.51 1.07-.63 1.8zM15.47 5.38c.68-.82 1.13-1.97.13-3.09 1.13.05 2.23.63 2.87 1.4.68.82 1.21 2 .1 3.09-.91.08-1.9-.53-2.47-1.4z"/></svg>
          </div>
          <div class="text-left">
            <p class="text-[10px] font-bold uppercase tracking-wider text-slate-500">Download on the</p>
            <p class="text-xl font-bold text-white">App Store</p>
          </div>
        </a>

        <a href="#" class="group relative flex items-center gap-4 bg-white/5 hover:bg-white/10 border border-white/10 p-6 rounded-2xl transition-all hover:scale-105 hover:border-primary/50">
          <div class="h-10 w-10 flex items-center justify-center">
            <svg viewBox="0 0 24 24" fill="white" class="h-8 w-8"><path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 01-.1-.12V1.934c0-.041.036-.08.1-.12zM14.5 12.707l2.833-2.833L20.666 12l-3.333 2.126-2.833-2.833zM4.317 22.607l10.183-10.183 3.333 3.333-12.183 7.77a.996.996 0 01-1.333-.92zM4.317 1.393L16.5 9.163l-3.333 3.333L4.317 1.393a.996.996 0 011.333-.92z"/></svg>
          </div>
          <div class="text-left">
            <p class="text-[10px] font-bold uppercase tracking-wider text-slate-500">Get it on</p>
            <p class="text-xl font-bold text-white">Google Play</p>
          </div>
        </a>
      </div>
    </div>

    <div class="mt-20 flex justify-center">
      <div class="relative max-w-sm w-full">
        <div class="absolute -inset-4 bg-primary/20 rounded-[48px] blur-2xl -z-10" />
        <img 
          src="https://framerusercontent.com/images/XyPZ0v3o1O5oXyPZ0v3o1O5oXy.png" 
          alt="App Screenshot" 
          class="rounded-[40px] border-4 border-white/10 shadow-2xl"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .text-gradient {
    background: linear-gradient(135deg, #10b981 0%, #3b82f6 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
</style>
