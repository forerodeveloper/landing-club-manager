---
const plans = [
  {
    n: "Club Manager",
    p: "$1,300",
    desc: "Tarifa por jugador al mes.",
    featured: true,
    f: [
      "Recaudo automático de mensualidades",
      "App móvil para padres con notificaciones",
      "Push notifications de pagos pendientes",
      "Gestión completa de jugadores y categorías",
      "Registro de asistencia",
      "Envío de convocatorias masivas",
      "Contabilidad y reportes automáticos",
      "Gestión de nómina de entrenadores",
      "Registro y aprobación de horas trabajadas",
      "Comunicación por WhatsApp predefinida",
      "Carnet digital de jugadores",
      "Dashboard con estadísticas en tiempo real",
      "Soporte técnico dedicado",
    ],
  },
];
---

<section id="pricing" class="mx-auto max-w-7xl px-4 py-24 sm:px-6">
  <div class="mx-auto max-w-2xl text-center">
    <p class="text-[11px] font-bold uppercase tracking-wider text-primary">Precios</p>
    <h2 class="mt-3 text-3xl font-bold tracking-tight sm:text-4xl">Gestiona tu club sin límites</h2>
    <p class="mt-4 text-muted-foreground">Un solo precio, todas las funcionalidades incluidas.</p>
  </div>

  <div class="mt-14 grid gap-6 lg:grid-cols-1 max-w-3xl mx-auto">
    {plans.map((pl) => (
      <div class={`relative rounded-3xl border p-8 shadow-soft ${pl.featured ? "border-primary bg-gradient-hero text-primary-foreground shadow-glow" : "border-border bg-card"}`}>
        {pl.featured && (
          <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-foreground px-3 py-1 text-[10px] font-bold uppercase tracking-wider text-background">
            Plan completo
          </span>
        )}
        <h3 class="text-lg font-semibold">{pl.n}</h3>
        <p class={`mt-1 text-sm ${pl.featured ? "text-primary-foreground/80" : "text-muted-foreground"}`}>{pl.desc}</p>
        <p class="mt-5 text-4xl font-bold">
          {pl.p}<span class={`text-base font-medium ${pl.featured ? "text-primary-foreground/70" : "text-muted-foreground"}`}> COP / jugador / mes</span>
        </p>
        <a href="https://wa.me/573204197482?text=Hola%2C%20me%20interesa%20solicitar%20Club%20Manager" target="_blank" class={`mt-6 inline-flex items-center justify-center w-full rounded-full text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 h-10 px-6 py-2 ${pl.featured ? "bg-background text-foreground hover:bg-background/90" : "bg-primary text-primary-foreground hover:bg-primary/90"}`}>
          Solicitar demo gratis
        </a>
        <ul class="mt-7 space-y-3">
          {pl.f.map((feat) => (
            <li class="flex items-start gap-2 text-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={`mt-0.5 flex-shrink-0 ${pl.featured ? "text-primary-foreground" : "text-primary"}`}>
                <path d="M20 6 9 17l-5-5"/>
              </svg>
              <span>{feat}</span>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>
