---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "ClubManager — Gestiona, cobra y haz crecer tu club deportivo",
	description = "Plataforma todo-en-uno para clubes deportivos: recaudo automático de padres, contabilidad, nómina de entrenadores, asistencia y comunicación por WhatsApp."
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/logo-single.png" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Canonical & Localization -->
		<link rel="canonical" href={Astro.url} />
		<link rel="alternate" hreflang="es" href={Astro.url} />
		<link rel="alternate" hreflang="x-default" href={Astro.url} />

		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />
		<meta name="keywords" content="club sport manager, gestión polideportiva, software academias deportivas, control asistencia multideporte, administración deportiva saas, gestión escuelas formación" />
		<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
		<meta name="author" content="Club Sport Manager" />

		<!-- Open Graph / Facebook -->
		<meta property="og:locale" content="es_ES">
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:site_name" content="ClubManager">
		<meta property="og:title" content="ClubManager — La plataforma para tu club deportivo" />
		<meta property="og:description" content="Recaudo, contabilidad, nómina y comunicación. Todo en un solo panel." />
		<meta property="og:image" content="/assets/og-image-csm.png" />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={Astro.url} />
		<meta property="twitter:title" content="ClubManager — La plataforma para tu club deportivo" />
		<meta property="twitter:description" content="Recaudo, contabilidad, nómina y comunicación. Todo en un solo panel." />
		<meta property="twitter:image" content="/assets/og-image-csm.png" />

		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

		<!-- Google Analytics (Uncomment and replace ID when ready) -->
		<!-- 
		<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());
			gtag('config', 'G-XXXXXXXXXX');
		</script> 
		-->
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	* {
		box-sizing: border-box;
	}

	body {
		margin: 0;
		min-height: 100vh;
	}
</style>

