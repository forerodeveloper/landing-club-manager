---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Club Sport Manager | Gestión para Clubes de Fútbol, Baloncesto, Tenis y más",
	description = "La plataforma SaaS definitiva para la administración de cualquier club deportivo. Control de pagos, asistencia y registro para fútbol, natación, artes marciales y más."
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/logo-single.png" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Canonical & Localization -->
		<link rel="canonical" href={Astro.url} />
		<link rel="alternate" hreflang="es" href={Astro.url} />
		<link rel="alternate" hreflang="x-default" href={Astro.url} />

		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />
		<meta name="keywords" content="club sport manager, gestión polideportiva, software academias deportivas, control asistencia multideporte, administración deportiva saas, gestión escuelas formación" />
		<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
		<meta name="author" content="Club Sport Manager" />

		<!-- Open Graph / Facebook -->
		<meta property="og:locale" content="es_ES">
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:site_name" content="Club Sport Manager">
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content="https://www.clubsportmanager.com/logo-horizontal-verde-2.png" />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={Astro.url} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content="https://www.clubsportmanager.com/logo-horizontal-verde-2.png" />

		<!-- Structured Data (JSON-LD) - Schema.org -->
		<script type="application/ld+json" is:inline>
			{
				"@context": "https://schema.org",
				"@type": "SoftwareApplication",
				"name": "Club Sport Manager",
				"operatingSystem": "iOS, Android, Web",
				"applicationCategory": "BusinessApplication, SportsApplication",
				"offers": {
					"@type": "Offer",
					"price": "0",
					"priceCurrency": "COP"
				},
				"description": "La plataforma SaaS definitiva para la administración de cualquier club deportivo. Control de pagos, asistencia, nómina de entrenadores y comunicación automática por WhatsApp.",
				"aggregateRating": {
					"@type": "AggregateRating",
					"ratingValue": "4.9",
					"ratingCount": "120"
				}
			}
		</script>
		<script type="application/ld+json" is:inline>
			{
				"@context": "https://schema.org",
				"@type": "Organization",
				"name": "Club Sport Manager",
				"url": "https://www.clubsportmanager.com",
				"logo": "https://www.clubsportmanager.com/logo-single.png",
				"sameAs": [
					"https://apps.apple.com/co/app/clubsport-manager/id6768074360",
					"https://play.google.com/store/apps/details?id=com.fordev.clubsportmanager"
				]
			}
		</script>

		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

		<!-- Google Analytics (Uncomment and replace ID when ready) -->
		<!-- 
		<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());
			gtag('config', 'G-XXXXXXXXXX');
		</script> 
		-->
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	* {
		box-sizing: border-box;
	}

	body {
		margin: 0;
		min-height: 100vh;
	}
</style>

